# CONFIGURACIÓN DEL SERVIDOR
# El puerto que usará el servidor (en local suele ser 5000)
PORT=5000

# Llave maestra para seguridad (cámbiala por algo difícil de adivinar)
SECRET_KEY=tu_clave_secreta_aqui

# Orígenes permitidos (CORS). Pon '*' para desarrollo o tu dominio para producción.
ALLOWED_ORIGINS=*

# CONFIGURACIÓN DEL JUEGO
# Tamaño de cada mitad del mapa (10 para un tablero total de 20)
GRID_HALF_SIZE=10
